# Application
APP_NAME=KePSLA Bot v2
APP_ENV=development
DEBUG=true
SECRET_KEY=your-secret-key-change-in-production

# Server
HOST=0.0.0.0
PORT=8000

# API Gateway
API_GATEWAY_AUTH_ENABLED=false
API_GATEWAY_API_KEY=
API_GATEWAY_RATE_LIMIT_ENABLED=true
API_GATEWAY_RATE_LIMIT_REQUESTS=80
API_GATEWAY_RATE_LIMIT_WINDOW_SECONDS=60

# Observability / Evaluation
OBSERVABILITY_ENABLED=true
OBSERVABILITY_LOG_FILE=./logs/observability.log
EVALUATION_METRICS_ENABLED=true
CONVERSATION_AUDIT_ENABLED=true
CONVERSATION_AUDIT_LOG_FILE=./logs/conversation_audit.jsonl

# Database (SQLite for dev - no setup needed!)
DATABASE_URL=sqlite+aiosqlite:///./kepsla_bot.db
DATABASE_ECHO=false
ADMIN_DB_FAST_FALLBACK_TIMEOUT_SECONDS=1.5
ADMIN_DB_UNAVAILABLE_BACKOFF_SECONDS=15
# For PostgreSQL (production):
# DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/kepsla_bot

# Redis
REDIS_URL=redis://localhost:6379/0

# OpenAI
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# LLM Settings
LLM_MAX_TOKENS=2000
LLM_TEMPERATURE=0.7
LLM_TIMEOUT=30

# RAG Settings
RAG_BACKEND=local
RAG_CHUNK_SIZE=220
RAG_CHUNK_OVERLAP=40
RAG_TOP_K=4
RAG_MIN_RETRIEVAL_SCORE=0.18
RAG_ENABLE_RERANK=true
RAG_ENABLE_MMR=true
RAG_MMR_LAMBDA=0.7
RAG_CANDIDATE_POOL_MIN=20
RAG_CANDIDATE_POOL_MAX=40
RAG_ENABLE_LLM_QUERY_REWRITE=true
RAG_LLM_QUERY_REWRITE_MAX_TOKENS=64
RAG_ENABLE_LLM_RERANK=false
RAG_STEP_LOGS_ENABLED=true
RAG_STEP_LOG_FILE=./logs/detailedsteps.log
RAG_STEP_LOG_PREVIEW_CHARS=260
RAG_LOCAL_INDEX_FILE=./data/rag/local_index.json
KB_DIRECT_LOOKUP_ENABLED=true
KB_DIRECT_LOOKUP_MIN_SCORE=0.34
KB_DIRECT_LOOKUP_MAX_ANSWER_CHARS=600
KB_DIRECT_LOOKUP_STEP_LOGS_ENABLED=true
KB_DIRECT_LOOKUP_ENABLE_LLM_REWRITE=true
KB_DIRECT_LOOKUP_LLM_REWRITE_MAX_TOKENS=64
KB_DIRECT_DISABLE_RAG_FALLBACK=true
AGENT_PLUGIN_RUNTIME_ENABLED=false
CHAT_FULL_KB_LLM_MODE=false
FULL_KB_LLM_MAX_KB_CHARS=180000
FULL_KB_LLM_MAX_HISTORY_MESSAGES=10
FULL_KB_LLM_STEP_LOGS_ENABLED=true
FULL_KB_LLM_TEMPERATURE=0.1
FULL_KB_LLM_PASSTHROUGH_MODE=false
FULL_KB_LLM_PRE_SHORTCUTS_ENABLED=false
CHAT_KB_ONLY_MODE=false
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=kepsla_kb_chunks
QDRANT_VECTOR_SIZE=1536

# Context Settings
MAX_CONVERSATION_HISTORY=20
CONTEXT_WINDOW_TOKENS=8000
SESSION_TTL_HOURS=24

# Confidence Thresholds
INTENT_CONFIDENCE_THRESHOLD=0.7
RESPONSE_CONFIDENCE_THRESHOLD=0.6
ESCALATION_THRESHOLD=0.4

# WhatsApp (for later)
WHATSAPP_API_URL=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# External Ticketing / Handoff (Lumira-compatible)
TICKETING_BASE_URL=
TICKETING_CREATE_PATH=/insert/ticket.htm
TICKETING_UPDATE_PATH_TEMPLATE=/insert/ticket/{ticket_id}.htm
TICKETING_TIMEOUT_SECONDS=10
TICKETING_LOCAL_MODE=false
TICKETING_LOCAL_STORE_FILE=./data/ticketing/local_tickets.json
TICKETING_LOCAL_CSV_FILE=
TICKETING_PLUGIN_ENABLED=true
TICKETING_PLUGIN_TAKEOVER_MODE=false
TICKETING_CASE_MATCH_USE_LLM=true
TICKETING_CASE_MATCH_MODEL=gpt-4o-mini
TICKETING_CASE_MATCH_FALLBACK_ENABLED=true
AGENT_HANDOFF_API_URL=

# Smart Ticket Routing
TICKETING_SMART_ROUTING_ENABLED=true
TICKETING_SMART_ROUTING_USE_LLM=true
TICKETING_ROUTER_MODEL=gpt-4o-mini
TICKETING_ROUTER_ACK_SIMILARITY=0.88
TICKETING_ROUTER_UPDATE_SIMILARITY=0.55
TICKETING_ENRICHMENT_ENABLED=true
TICKETING_AUTO_CREATE_ON_ACTIONABLE=true
TICKETING_SUBCATEGORY_LLM_ENABLED=false
TICKETING_SUBCATEGORY_MODEL=gpt-4o-mini
TICKETING_STALE_RECONFIRM_ENABLED=false
TICKETING_STALE_RECONFIRM_MINUTES=30
TICKETING_GUEST_PREFERENCES_ENABLED=false
TICKETING_GUEST_PREFERENCES_USE_LLM=false
TICKETING_GUEST_PREFERENCES_MODEL=gpt-4o-mini
TICKETING_IDENTITY_GATE_ENABLED=false
TICKETING_IDENTITY_GATE_PREBOOKING_ONLY=true
TICKETING_IDENTITY_REQUIRE_NAME=true
TICKETING_IDENTITY_REQUIRE_PHONE=true
