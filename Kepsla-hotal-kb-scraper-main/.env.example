# ── OpenAI (for LLM-based KB structuring) ──
OPENAI_API_KEY=sk-...

# ── App Settings ──
APP_PORT=8501
APP_ENV=development

# ── Scraper Settings ──
MAX_PAGES_PER_SITE=150
MAX_CONCURRENT_CRAWLS=5
CRAWL_DELAY_SECONDS=1.5
MAX_DEPTH=3

# ── Proxy / IP Reputation Bypass (optional) ──
# Use a residential proxy so Akamai/PerimeterX don't block your datacenter IP.
# Any provider works (Oxylabs, SOAX, IPRoyal, Smartproxy, etc.).
# Format: http://username:password@proxy-host:port
# RESIDENTIAL_PROXY_URL=http://user:pass@gate.example.com:8000

# Bright Data Scraping Browser (premium — bypasses Akamai + behavioural checks).
# Get the WSS URL from: Bright Data dashboard → Scraping Browser → Access Parameters
# BRIGHT_DATA_WS_URL=wss://brd-customer-hl_xxxxx-zone-scraping_browser1:password@brd.superproxy.io:9222
